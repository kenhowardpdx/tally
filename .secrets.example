# Secrets Configuration for Local GitHub Actions Testing
# Copy this file to .secrets and fill in your actual values
# .secrets is in .gitignore and will not be committed to version control

# AWS Configuration for Local Testing
AWS_PROFILE=your-sso-profile-name  # Must match a profile in ~/.aws/config (SSO or static)

# AWS Role ARN for GitHub Actions OIDC authentication
# This is the role that GitHub Actions will assume when running workflows
# Format: arn:aws:iam::ACCOUNT_ID:role/ROLE_NAME
AWS_ROLE_ARN=arn:aws:iam::123456789012:role/tally-github-actions-role

# Terraform Variables for Local Development
# These are automatically loaded as TF_VAR_* environment variables
# GitHub Actions will use repository secrets instead
TF_VAR_aws_account_id=123456789012
TF_VAR_aws_profile=AdministratorAccess-123456789012

# Required for ACT and Terraform workflows:
AWS_ACCESS_KEY_ID=EXAMPLEACCESSKEYID
AWS_SECRET_ACCESS_KEY=EXAMPLESECRETACCESSKEY
AWS_SESSION_TOKEN=EXAMPLESESSIONTOKEN
AWS_ACCOUNT_ID=123456789012
AWS_DEFAULT_REGION=us-west-2

# Neon (Postgres) Configuration
# GitHub Actions uses repository secrets instead (TALLY_DATABASE_URL_READWRITE / TALLY_DATABASE_URL_READONLY)
NEON_API_KEY=neon_api_key_example
TF_VAR_neon_org_id=org-example-12345678
TF_VAR_neon_project_id=example-project-123456
# Connection strings from the Neon console - keep the surrounding single quotes,
# the querystring contains an unescaped `&` that bash would otherwise treat as a job-control operator
TF_VAR_database_url_readwrite='postgresql://user:password@ep-example-pooler.us-west-2.aws.neon.tech/dbname?sslmode=require&channel_binding=require'
TF_VAR_database_url_readonly='postgresql://user:password@ep-example-pooler.us-west-2.aws.neon.tech/dbname?sslmode=require&channel_binding=require'

# Usage:
# - Source this file in your shell before running ACT or Makefile targets
# - All variables above are required for Terraform and GitHub Actions workflows
# - Replace EXAMPLE* values with your actual credentials for local use
