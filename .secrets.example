# Local Development Configuration
# Copy this file to .secrets and fill in your actual values
# .secrets is in .gitignore and will not be committed to version control

# ============================================================================
# AWS SSO Configuration (for local Terraform development)
# ============================================================================
# Your AWS SSO profile name from ~/.aws/config
# This is all you need for local terraform operations via scripts/tf-local
AWS_PROFILE=AdministratorAccess-123456789012

# Your AWS Account ID (12 digits)
TF_VAR_aws_account_id=123456789012

# Optional: Override default region (default: us-west-2)
# AWS_DEFAULT_REGION=us-west-2

# Optional: Override default environment (default: dev for local)
# TF_VAR_environment=dev

# ============================================================================
# Neon Database Configuration
# ============================================================================
# Get your API key from: https://console.neon.tech/app/settings/api-keys
NEON_API_KEY=napi_your_api_key_here

# Shared Neon project ID (created in dev workspace)
# Project: example-project-12345678
TF_VAR_neon_project_id=example-project-12345678

# ============================================================================
# GitHub Actions Testing with ACT (optional)
# ============================================================================
# Only needed if you want to test GitHub Actions workflows locally with ACT
# These are temporary AWS credentials that expire after a few hours
# Run scripts/export-aws-credentials.sh to populate these automatically

AWS_ACCESS_KEY_ID=EXAMPLEACCESSKEYID
AWS_SECRET_ACCESS_KEY=EXAMPLESECRETACCESSKEY
AWS_SESSION_TOKEN=EXAMPLESESSIONTOKEN
AWS_ACCOUNT_ID=123456789012

# GitHub Actions role ARN (for ACT simulation only)
AWS_ROLE_ARN=arn:aws:iam::123456789012:role/tally-github-actions-role

# ============================================================================
# Usage Patterns
# ============================================================================
# 
# Local Terraform Development (RECOMMENDED):
#   ./scripts/tf-local init    # Initialize with S3 backend + local-dev workspace
#   ./scripts/tf-local plan    # Plan changes
#   ./scripts/tf-local apply   # Apply changes to local-dev workspace
#   ./scripts/tf-local destroy # Destroy local-dev infrastructure
#
# GitHub Actions Testing with ACT:
#   ./scripts/export-aws-credentials.sh  # Export SSO creds to .secrets
#   make github_workflow_terraform-pr    # Test PR workflow locally
