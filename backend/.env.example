# Copy to .env for local development (already in .gitignore).
# Mirrors the shape of the Neon connection strings used in prod (see infra/variables.tf),
# but points at the docker-compose Postgres service instead.
DATABASE_URL_READWRITE=postgresql+asyncpg://tally:tally@localhost:5433/tally

# Auth0 tenant settings (Phase 0.4) — fill in after creating the Auth0 tenant/API.
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.tally.example.com
