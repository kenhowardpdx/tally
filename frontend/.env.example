# Copy to .env for local development (already in .gitignore).
# PUBLIC_ prefix is required for SvelteKit to inline these into the client bundle.

PUBLIC_AUTH0_DOMAIN=your-tenant.us.auth0.com
PUBLIC_AUTH0_CLIENT_ID=your-auth0-spa-client-id
PUBLIC_AUTH0_AUDIENCE=https://api.tally.example.com

PUBLIC_API_BASE_URL=http://localhost:8000
