#!/usr/bin/env bash
# Terraform Local Development Wrapper
# Usage: ./scripts/tf-local [init|plan|apply|destroy]
#
# This script simplifies local Terraform development by:
# - Using AWS SSO profile authentication (no credential exports needed)
# - Using the same S3 backend as CI/CD (with local workspace for safety)
# - Allowing full terraform commands locally without breaking CI/CD

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
INFRA_DIR="$PROJECT_ROOT/infra"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Load AWS_PROFILE and account ID from .secrets if available
if [[ -f "$PROJECT_ROOT/.secrets" ]]; then
    source "$PROJECT_ROOT/.secrets"
fi

# Save Neon variables before unsetting AWS credentials
NEON_KEY="${NEON_API_KEY}"
NEON_ORG="${TF_VAR_neon_org_id}"
NEON_PROJECT="${TF_VAR_neon_project_id}"

# Unset temporary AWS credentials so that AWS_PROFILE is used instead
# (Temporary credentials take precedence over profile, causing auth failures)
unset AWS_ACCESS_KEY_ID
unset AWS_SECRET_ACCESS_KEY
unset AWS_SESSION_TOKEN

# Restore Neon variables
export NEON_API_KEY="${NEON_KEY}"
export TF_VAR_neon_org_id="${NEON_ORG}"
export TF_VAR_neon_project_id="${NEON_PROJECT}"

# Check required variables
if [[ -z "$AWS_PROFILE" ]]; then
    echo -e "${RED}Error: AWS_PROFILE not set${NC}"
    echo "Add to .secrets file: AWS_PROFILE=AdministratorAccess-123456789012"
    exit 1
fi

if [[ -z "$TF_VAR_aws_account_id" ]] && [[ -z "$AWS_ACCOUNT_ID" ]]; then
    echo -e "${RED}Error: AWS account ID not set${NC}"
    echo "Add to .secrets file: TF_VAR_aws_account_id=123456789012"
    exit 1
fi

# Use TF_VAR_aws_account_id or fall back to AWS_ACCOUNT_ID
export TF_VAR_aws_account_id="${TF_VAR_aws_account_id:-$AWS_ACCOUNT_ID}"
export TF_VAR_aws_profile="$AWS_PROFILE"
export TF_VAR_environment="${TF_VAR_environment:-dev}"
export AWS_REGION="${AWS_DEFAULT_REGION:-us-west-2}"
export AWS_PAGER=""  # Disable pager for AWS CLI commands

# Ensure SSO session is valid
echo -e "${YELLOW}Checking AWS SSO session...${NC}"
if ! aws sts get-caller-identity --profile "$AWS_PROFILE" >/dev/null 2>&1; then
    echo -e "${YELLOW}AWS SSO session expired. Logging in...${NC}"
    aws sso login --profile "$AWS_PROFILE"
fi

# Get account info briefly
ACCOUNT_ID=$(aws sts get-caller-identity --profile "$AWS_PROFILE" --query Account --output text 2>/dev/null)
echo -e "${GREEN}✓ Authenticated to AWS account: $ACCOUNT_ID${NC}"

# Export SSO credentials to environment for Terraform
echo -e "${YELLOW}Exporting SSO credentials for Terraform...${NC}"
eval "$(aws configure export-credentials --profile "$AWS_PROFILE" --format env)"

cd "$INFRA_DIR"

# Handle terraform commands
case "${1:-plan}" in
    init)
        echo -e "${YELLOW}Initializing Terraform with S3 backend...${NC}"
        
        # Create backend.tf dynamically
        cat > backend.tf <<EOF
terraform {
  backend "s3" {}
}
EOF
        
        # Create backend config
        sed "s/__AWS_ACCOUNT_ID__/$TF_VAR_aws_account_id/g" backend.conf > backend.conf.tmp
        
        # Initialize with backend config
        terraform init -reconfigure -backend-config=backend.conf.tmp
        rm backend.conf.tmp
        
        # Select or create local development workspace
        echo -e "${YELLOW}Setting up local development workspace...${NC}"
        if terraform workspace list | grep -q "local-dev"; then
            terraform workspace select local-dev
        else
            terraform workspace new local-dev
        fi
        
        echo -e "${GREEN}✓ Terraform initialized with workspace: local-dev${NC}"
        ;;
        
    plan)
        echo -e "${YELLOW}Running terraform plan...${NC}"
        terraform plan
        ;;
        
    apply)
        echo -e "${RED}⚠️  This will apply changes to AWS infrastructure${NC}"
        echo -e "${YELLOW}Workspace: $(terraform workspace show)${NC}"
        echo -e "${YELLOW}Environment: $TF_VAR_environment${NC}"
        echo ""
        read -p "Continue? (yes/no): " confirm
        if [[ "$confirm" != "yes" ]]; then
            echo "Aborted."
            exit 0
        fi
        terraform apply
        ;;
        
    destroy)
        echo -e "${RED}⚠️  This will DESTROY all infrastructure in current workspace${NC}"
        echo -e "${YELLOW}Workspace: $(terraform workspace show)${NC}"
        echo -e "${YELLOW}Environment: $TF_VAR_environment${NC}"
        echo ""
        read -p "Type 'destroy' to confirm: " confirm
        if [[ "$confirm" != "destroy" ]]; then
            echo "Aborted."
            exit 0
        fi
        terraform destroy
        ;;
        
    *)
        # Pass through any other terraform command
        terraform "$@"
        ;;
esac
